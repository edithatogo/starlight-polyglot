{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "group:allNonMajor", ":automergePatch"],
  "packageRules": [
    {
      "matchUpdateTypes": ["pin", "digest"],
      "automerge": true
    },
    {
      "matchPackageNames": ["@astrojs/starlight", "astro"],
      "groupName": "starlight monorepo",
      "automerge": false,
      "labels": ["starlight"]
    }
  ],
  "labels": ["dependencies"],
  "semanticCommitType": "chore"
}
