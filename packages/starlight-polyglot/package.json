{
  "name": "starlight-polyglot",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Starlight plugin to generate documentation from any programming language using its native toolchain.",
  "author": "Dylan A Mordaunt <dylan@mordaunt.dev>",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts --clean",
    "dev": "tsup index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --cache --max-warnings=0",
    "format": "prettier --write '**/*.{ts,json,md}'",
    "format:check": "prettier --check '**/*.{ts,json,md}'",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "prepublish": "pnpm build",
    "release": "changeset publish"
  },
  "dependencies": {
    "github-slugger": "^2.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.15",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "size-limit": "^11.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@astrojs/starlight": ">=0.39.0",
    "astro": ">=6.3.1",
    "typedoc": ">=0.28.0",
    "typedoc-plugin-markdown": ">=4.6.0"
  },
  "peerDependenciesMeta": {
    "typedoc": {
      "optional": true
    },
    "typedoc-plugin-markdown": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "keywords": [
    "starlight",
    "plugin",
    "polyglot",
    "documentation",
    "astro",
    "python",
    "typescript",
    "rust",
    "r",
    "julia",
    "csharp",
    "go"
  ],
  "homepage": "https://github.com/edithatogo/starlight-polyglot",
  "repository": {
    "type": "git",
    "url": "https://github.com/edithatogo/starlight-polyglot.git",
    "directory": "packages/starlight-polyglot"
  },
  "bugs": "https://github.com/edithatogo/starlight-polyglot/issues"
}
