{
  "name": "starlight-polyglot-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for starlight-polyglot — multi-language documentation plugin for Starlight",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter starlight-polyglot build",
    "dev": "pnpm --filter starlight-polyglot dev",
    "test": "pnpm --filter starlight-polyglot test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "pnpm -r format",
    "clean": "pnpm --filter starlight-polyglot clean",
    "docs:dev": "pnpm --filter starlight-polyglot-docs dev",
    "docs:build": "pnpm --filter starlight-polyglot-docs build",
    "docs:preview": "pnpm --filter starlight-polyglot-docs preview"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
